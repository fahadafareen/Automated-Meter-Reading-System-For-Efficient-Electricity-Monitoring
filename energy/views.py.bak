def pay(request):
    if request.method=='POST':
        a=request.POST.get('id')
        b=request.POST.get('paymenttype')
        c=request.POST.get('bill_amount')
        d=request.POST.get('cardnum')
        e=request.POST.get('ccvnum')
        f=request.POST.get('expdate')
        g=request.POST.get('date')
        h=request.POST.get('status')
        # POST, generate bound form with data from the request
        payt=payment(billid=a,paymenttype=b,bill_amount=c,cardnum=d,ccvnum=e,expdate=f,date=g,status=h)
        payt.save()
        return  render(request,'consumer/payment.html')        

