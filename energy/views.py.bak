def billss(request):
    if request.method=='POST':
        a=request.POST.get('cid')
        b=request.POST.get('date')
        c=request.POST.get('billamount')
        d=request.POST.get('duedate')
        e=request.POST.get('status')
        f=request.POST.get('customer_id')

        ana=bills(consumerid=a,date=b,bill_amount=c,due_date=d,status=e,cid=f)
        ana.save()
        return  render(request,'admin/bill.html')