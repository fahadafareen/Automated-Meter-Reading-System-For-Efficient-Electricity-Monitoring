def conss(request):
    if request.method=='POST':
        a=request.POST.get('name')
     
        f=request.POST.get('meternumber')
        user=meter.objects.get(meternumber=f)
        a=user.meternumber
        status='approved'
        id=user.id
        userr=meter(meternumber=a,status=status,id=id)
        userr.save()
        # POST, generate bound form with data from the request
        use=consumerr(name=a,meter_number=f)
        use.save()
        return  render(request,'admin/consumer.html')         
    
