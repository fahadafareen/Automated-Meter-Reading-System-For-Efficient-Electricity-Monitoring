def addreg(request):
    if request.method == 'POST':
        name=request.POST.get('name')
        phone=request.POST.get('phone')
        email=request.POST.get('email')
        password=request.POST.get('password')
        address=request.POST.get('address')
        location=request.POST.get('location')
        # POST, generate bound form with data from the request
        user=registration(name=name,phone=phone,email=email,password=password,address=address,location=location)
        user.save()
        return render(request,'register.html')
        
def comp(request):
     uid=request.session['uid']
     uname=request.session['uname']
     if request.method=='POST':
        complaintname=request.POST.get('complaintname')
        description=request.POST.get('description')
        uploaded_file=request.FILES['image']
        print(uploaded_file)
        fs = FileSystemStorage()
        name = fs.save(uploaded_file.name,uploaded_file)
        date=request.POST.get('date')
        status=request.POST.get('status')
        compt=complaints(consumerid=uname,complaintname=complaintname,description=description,photoss=uploaded_file,date=date,status=status,cid=uid)
        compt.save()    
        return render(request,'consumer/complaint.html')    

